    "latex": "\\left( -\\frac{\\hbar^2}{2m}\\nabla^2 + v_{\\text{eff}}(\\mathbf{r}) \\right)\\psi_i(\\mathbf{r}) = \\varepsilon_i\\, \\psi_i(\\mathbf{r})",
