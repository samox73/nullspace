  {
    "id": "00000000-0000-4000-8000-00000000d004",
    "name": "Hohenberg-Kohn variational principle",
    "description": "Second Hohenberg-Kohn theorem: the exact energy functional is minimized by the true ground-state density and equals the ground-state energy there.",
    "latex": "E_0 = \\min_{n}\\, E[n], \\qquad E[n] \\geq E_0",
