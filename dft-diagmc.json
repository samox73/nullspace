    "latex": "\\hat{H} = -\\frac{\\hbar^2}{2m}\\sum_i \\nabla_i^2 + \\sum_i v_{\\text{ext}}(\\mathbf{r}_i) + \\frac{1}{2}\\sum_{i\\neq j}\\frac{e^2}{|\\mathbf{r}_i-\\mathbf{r}_j|}",
    "references": [],
